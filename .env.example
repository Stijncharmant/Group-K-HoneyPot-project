# Copy to ".env" and adjust to match your existing local MySQL.
# docker compose reads .env automatically.

# --- Connection to your EXISTING host MySQL ---
# DB_HOST: leave as host.docker.internal to reach MySQL on the Docker host.
#          (Set to a hostname/IP if your DB lives elsewhere.)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=carparts
DB_USER=root
DB_PASSWORD=sophie

# --- Host ports for the app containers (host:container) ---
API_PORT=5183
WEBAPP_PORT=5123

# --- ASP.NET environment ---
# Development = Swagger UI on the API + detailed errors. Use Production to lock down.
ASPNETCORE_ENVIRONMENT=Development

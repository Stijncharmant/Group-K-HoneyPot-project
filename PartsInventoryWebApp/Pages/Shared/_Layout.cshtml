<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PartsInventoryWebApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PartsInventoryWebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="">PartsInventoryWebApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area=""></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area=""></a>
                        </li>
                    </ul>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav align-items-center">
                            <li class="nav-item me-3">
                                <span class="navbar-text text-muted small">
                                    Welcome, <strong>@User.Identity.Name</strong>
                                </span>
                            </li>
                            <li class="nav-item">
                                <button type="button" class="btn btn-outline-danger btn-sm px-3 rounded-pill fw-medium" data-bs-toggle="modal" data-bs-target="#logoutConfirmationModal">
                                    Logout
                                </button>
                            </li>
                        </ul>
                    }

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PartsInventoryWebApp - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <div class="modal fade" id="logoutConfirmationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered execution-modal">
            <div class="modal-content border-0 modern-modal shadow-lg">
                <div class="modal-body p-4 text-center">
                    <div class="logout-icon-wrapper mb-3 mx-auto">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="text-danger bi bi-box-arrow-right" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z" />
                            <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z" />
                        </svg>
                    </div>

                    <h5 class="fw-bold text-dark mb-2">Signing Out?</h5>
                    <p class="text-muted small mb-4">Are you sure you want to log out of your Car Parts Inventory session?</p>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-light custom-modal-btn border px-4 py-2" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <form method="post" asp-page="/Inventory" asp-page-handler="Logout" class="d-inline">
                            <button type="submit" class="btn btn-danger custom-modal-btn px-4 py-2 fw-semibold shadow-sm">
                                Yes, Logout
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
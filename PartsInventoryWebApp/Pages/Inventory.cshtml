@page
@model PartsInventoryWebApp.Pages.InventoryModel
@{
}

<div class="inventory-container">

    <div class="inventory-header">
        <div class="header-titles">
            <h1 class="page-title">Inventory</h1>
            <p class="text-muted text-sm">Manage your parts, pricing, and current stock levels.</p>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <button class="btn btn-primary btn-add" data-bs-toggle="modal" data-bs-target="#addPartModal">
                <i class="bi bi-plus-lg"></i> Add Part
            </button>
        }
    </div>

    <div class="inventory-card">
        <div class="table-responsive">
            <table class="table modern-table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Part Details</th>
                        <th scope="col">Price</th>
                        <th scope="col">Status</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var part in Model.Parts)
                    {
                        <tr>
                            <td>
                                <div class="part-info">
                                    <span class="part-name">@part.Name</span>
                                    <span class="part-sku">@part.Sku</span>
                                </div>
                            </td>
                            <td class="part-price">€@part.Price.ToString("0.00")</td>

                            <td>
                                @if (part.Quantity <= 5)
                                {
                                    <span class="modern-badge badge-danger">
                                        <span class="status-dot"></span> @part.Quantity in stock
                                    </span>
                                }
                                else
                                {
                                    <span class="modern-badge badge-success">
                                        <span class="status-dot"></span> @part.Quantity in stock
                                    </span>
                                }
                            </td>

                            <td class="text-end">
                                @if (User.IsInRole("Admin"))
                                {
                                    <button class="btn btn-sm btn-action btn-edit-trigger" data-part-id="@part.Id">
                                        Edit
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">View Only</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="pagination-container">
        <button class="btn btn-outline-secondary btn-paginate" @(Model.CurrentPage == 1 ? "disabled" : "")>
            Previous
        </button>

        <span class="pagination-text">
            Page <strong>@Model.CurrentPage</strong> of <strong>@Model.TotalPages</strong>
        </span>

        <button class="btn btn-outline-secondary btn-paginate" @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")>
            Next
        </button>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="modal fade" id="addPartModal" tabindex="-1" aria-labelledby="addPartModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 custom-part-modal shadow-lg">

                    <div class="modal-header border-bottom-0 pt-4 px-4">
                        <div>
                            <h5 class="modal-title fw-bold text-dark" id="addPartModalLabel">Add New Part Asset</h5>
                            <p class="text-muted small mb-0">Fill in the specification details to initialize inventory logs.</p>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <form method="post" asp-page-handler="AddPart">
                        <div class="modal-body px-4 pb-4">

                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label asp-for="NewPart.Name" class="form-label small fw-semibold text-secondary">Part Name</label>
                                    <input asp-for="NewPart.Name" class="form-control modern-input" placeholder="e.g. Brake Pads" />
                                    <span asp-validation-for="NewPart.Name" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="NewPart.Sku" class="form-label small fw-semibold text-secondary">SKU Code</label>
                                    <input asp-for="NewPart.Sku" type="number" class="form-control modern-input" placeholder="10001" />
                                    <span asp-validation-for="NewPart.Sku" class="text-danger small"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="NewPart.Description" class="form-label small fw-semibold text-secondary">Description</label>
                                    <textarea asp-for="NewPart.Description" class="form-control modern-input" rows="2" placeholder="Provide part specs, dimensions or placement notes..."></textarea>
                                    <span asp-validation-for="NewPart.Description" class="text-danger small"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="NewPart.Price" class="form-label small fw-semibold text-secondary">Unit Price (€)</label>
                                    <input asp-for="NewPart.Price" class="form-control modern-input" placeholder="49.99" />
                                    <span asp-validation-for="NewPart.Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="NewPart.Quantity" class="form-label small fw-semibold text-secondary">Initial Stock Level</label>
                                    <input asp-for="NewPart.Quantity" type="number" class="form-control modern-input" placeholder="10" />
                                    <span asp-validation-for="NewPart.Quantity" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="NewPart.Year" class="form-label small fw-semibold text-secondary">Model Compatibility Year</label>
                                    <input asp-for="NewPart.Year" type="number" class="form-control modern-input" placeholder="2026" />
                                    <span asp-validation-for="NewPart.Year" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="NewPart.CategoryId" class="form-label small fw-semibold text-secondary">Category Reference ID</label>
                                    <input asp-for="NewPart.CategoryId" type="number" class="form-control modern-input" placeholder="3" />
                                    <span asp-validation-for="NewPart.CategoryId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="NewPart.ManufacturerId" class="form-label small fw-semibold text-secondary">Manufacturer Reference ID</label>
                                    <input asp-for="NewPart.ManufacturerId" type="number" class="form-control modern-input" placeholder="12" />
                                    <span asp-validation-for="NewPart.ManufacturerId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer border-top-0 px-4 pb-4 pt-0">
                            <button type="button" class="btn btn-light px-4 border text-secondary" data-bs-dismiss="modal" style="border-radius:8px;">Cancel</button>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius:8px; background-color:#0d6efd;">Save Asset</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade" id="editPartModal" tabindex="-1" aria-labelledby="editPartModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 custom-part-modal shadow-lg">

                    <div class="modal-header border-bottom-0 pt-4 px-4">
                        <div>
                            <h5 class="modal-title fw-bold text-dark" id="editPartModalLabel">Modify Part Asset Specifications</h5>
                            <p class="text-muted small mb-0">Apply adjustments to system variables below to adjust tracking telemetry logs.</p>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <form method="post" asp-page-handler="EditPart">
                        <input type="hidden" asp-for="EditPartId" id="editPartId" />

                        <div class="modal-body px-4 pb-4">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label asp-for="NewPart.Name" class="form-label small fw-semibold text-secondary">Part Name</label>
                                    <input asp-for="NewPart.Name" id="editPartName" class="form-control modern-input" />
                                    <span asp-validation-for="NewPart.Name" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="NewPart.Sku" class="form-label small fw-semibold text-secondary">SKU Code</label>
                                    <input asp-for="NewPart.Sku" id="editPartSku" class="form-control modern-input" />
                                    <span asp-validation-for="NewPart.Sku" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="NewPart.Description" class="form-label small fw-semibold text-secondary">Description</label>
                                    <textarea asp-for="NewPart.Description" id="editPartDescription" class="form-control modern-input" rows="2"></textarea>
                                    <span asp-validation-for="NewPart.Description" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="NewPart.Price" class="form-label small fw-semibold text-secondary">Unit Price (€)</label>
                                    <input asp-for="NewPart.Price" id="editPartPrice" class="form-control modern-input" />
                                    <span asp-validation-for="NewPart.Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="NewPart.Quantity" class="form-label small fw-semibold text-secondary">Current Stock Level</label>
                                    <input asp-for="NewPart.Quantity" id="editPartQuantity" type="number" class="form-control modern-input" />
                                    <span asp-validation-for="NewPart.Quantity" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="NewPart.Year" class="form-label small fw-semibold text-secondary">Model Year</label>
                                    <input asp-for="NewPart.Year" id="editPartYear" type="number" class="form-control modern-input" />
                                    <span asp-validation-for="NewPart.Year" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="NewPart.CategoryId" class="form-label small fw-semibold text-secondary">Category Reference ID</label>
                                    <input asp-for="NewPart.CategoryId" id="editPartCategoryId" type="number" class="form-control modern-input" />
                                    <span asp-validation-for="NewPart.CategoryId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="NewPart.ManufacturerId" class="form-label small fw-semibold text-secondary">Manufacturer Reference ID</label>
                                    <input asp-for="NewPart.ManufacturerId" id="editPartManufacturerId" type="number" class="form-control modern-input" />
                                    <span asp-validation-for="NewPart.ManufacturerId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-top-0 px-4 pb-4 pt-0">
                            <button type="button" class="btn btn-light px-4 border text-secondary" data-bs-dismiss="modal" style="border-radius:8px;">Cancel</button>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius:8px; background-color:#0ea5e9; border:none;">Apply Adjustments</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Add Modal Persistence Guard
            @if (User.IsInRole("Admin") && ViewData["KeepModalOpen"] != null && (bool)ViewData["KeepModalOpen"])
            {
                    <text>
                    var addModal = new bootstrap.Modal(document.getElementById('addPartModal'));
                    addModal.show();
                    </text>
            }

            // Edit Modal Persistence Guard
            @if (User.IsInRole("Admin") && ViewData["KeepEditModalOpen"] != null && (bool)ViewData["KeepEditModalOpen"])
            {
                    <text>
                    var editModal = new bootstrap.Modal(document.getElementById('editPartModal'));
                    editModal.show();
                    </text>
            }

            // CLICK LISTENER FOR THE EDIT BUTTONS
            document.querySelectorAll('.btn-edit-trigger').forEach(button => {
                button.addEventListener('click', async function () {
                    const id = this.getAttribute('data-part-id');

                    try {
                        const response = await fetch(`?handler=PartDetails&id=${id}`);

                        if (response.ok) {
                            const data = await response.json();

                            // Map the incoming JSON object directly to the Edit Form Elements
                            document.getElementById('editPartId').value = id;
                            document.getElementById('editPartName').value = data.name;
                            document.getElementById('editPartSku').value = data.sku;
                            document.getElementById('editPartDescription').value = data.description || '';
                            document.getElementById('editPartPrice').value = data.price;
                            document.getElementById('editPartQuantity').value = data.quantity;
                            document.getElementById('editPartYear').value = data.year;
                            document.getElementById('editPartCategoryId').value = data.categoryId;
                            document.getElementById('editPartManufacturerId').value = data.manufacturerId;

                            // Display populated form context natively to admin view
                            var modalInstance = new bootstrap.Modal(document.getElementById('editPartModal'));
                            modalInstance.show();
                        } else {
                            alert("Failed to retrieve asset telemetry logs from backend channel.");
                        }
                    } catch (error) {
                        console.error("Error communicating with internal handler pipe:", error);
                    }
                });
            });
        });
    </script>
}